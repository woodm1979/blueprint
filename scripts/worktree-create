#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="${1:?Usage: worktree-create <repo-root> <branch-name> [<base-ref>] [<existing-worktree-dir>]}"
BRANCH="${2:?Usage: worktree-create <repo-root> <branch-name> [<base-ref>] [<existing-worktree-dir>]}"
BASE="${3:-}"
# Optional: a worktree another tool already created (e.g. herdr, which fires
# worktree.created *after* its own `git worktree add`). When set, Concern 1
# (creation) is skipped and we provision this directory in place.
EXISTING_WT="${4:-}"
# Provisioning-failure policy: "remove" (default — undo a worktree this script
# created) or "keep" (a worktree another tool owns; report but never delete it).
ON_FAIL="${WT_PROVISION_ON_FAIL:-remove}"

. "$(dirname "$0")/worktree-lib.sh"

# Concern 1 — Creation. Detect bare-vs-standard once, up front, then pick the
# tool-owned default path for that layout.
detect_layout "$REPO_ROOT"
if [[ "$WT_LAYOUT" == bare ]]; then
  # Bare: sibling of .bare inside the container, dir name = canonical slug.
  WORKTREE_DIR="$WT_CONTAINER/$(slugify "$BRANCH")"
  INCLUDE_SOURCE="$WT_CONTAINER"
else
  # Standard: <parent>/<repo>-worktrees/<branch> (historical default).
  WORKTREE_DIR="$(dirname "$REPO_ROOT")/$(basename "$REPO_ROOT")-worktrees/$BRANCH"
  INCLUDE_SOURCE="$REPO_ROOT"
fi

# When provisioning an already-created worktree, honor its actual path (the
# creating tool chose it); INCLUDE_SOURCE above still derives from the layout.
if [[ -n "$EXISTING_WT" ]]; then
  WORKTREE_DIR="$EXISTING_WT"
fi

# Copy a directory cheaply: APFS copy-on-write clone (instant, isolated on
# write), falling back to hard-links on filesystems without clonefile.
clone_dir() {
  local src="$1" dst="$2"
  cp -c -R "$src" "$dst" 2>/dev/null || cp -Rl "$src" "$dst"
}

if [[ -z "$EXISTING_WT" ]]; then
  # Concern 1 — Creation (only when we own it).
  if [[ -e "$WORKTREE_DIR" ]]; then
    echo "Error: '$WORKTREE_DIR' already exists — refusing to clobber. Remove it first (worktree-remove)." >&2
    exit 1
  fi

  git -C "$REPO_ROOT" worktree prune >&2

  if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
    echo "Branch '$BRANCH' already exists, checking it out..." >&2
    git -C "$REPO_ROOT" worktree add "$WORKTREE_DIR" "$BRANCH" >&2
  elif git -C "$REPO_ROOT" show-ref --verify --quiet "refs/remotes/origin/$BRANCH"; then
    echo "Tracking existing origin/$BRANCH..." >&2
    git -C "$REPO_ROOT" worktree add --track -b "$BRANCH" "$WORKTREE_DIR" "origin/$BRANCH" >&2
  else
    echo "Creating new branch '$BRANCH'${BASE:+ from $BASE}..." >&2
    git -C "$REPO_ROOT" worktree add -b "$BRANCH" "$WORKTREE_DIR" ${BASE:+"$BASE"} >&2
  fi
else
  # Creation already done by another tool (e.g. herdr). Verify, then provision in place.
  if ! git -C "$WORKTREE_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: '$WORKTREE_DIR' is not a git worktree — cannot provision." >&2
    exit 1
  fi
  echo "Provisioning existing worktree: $WORKTREE_DIR" >&2
fi

# Worktree now exists — arm cleanup so a later setup failure removes only what
# this run created. Never remove a worktree another tool owns (ON_FAIL=keep).
if [[ "$ON_FAIL" == remove ]]; then
  trap 'echo "Setup failed, removing worktree..." >&2; git -C "$REPO_ROOT" worktree remove --force "$WORKTREE_DIR" 2>/dev/null || true' ERR
fi

# Concern 2 — File-bringing. A repo-root .worktreeinclude (gitignore syntax) is
# authoritative when present: each line is a gitignored/shared path to bring in.
# Default action is copy; a leading '&' marks symlink (to the canonical source).
# Source base is the container for bare layouts, the repo root for standard.
if [[ -f "$REPO_ROOT/.worktreeinclude" ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    # Strip surrounding whitespace; skip blanks and comments.
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" || "$line" == \#* ]] && continue

    mode=copy
    if [[ "$line" == \&* ]]; then
      mode=symlink
      line="${line#&}"
      line="${line#"${line%%[![:space:]]*}"}"
    fi

    src="$INCLUDE_SOURCE/$line"
    dst="$WORKTREE_DIR/$line"
    if [[ ! -e "$src" ]]; then
      echo "Warning: .worktreeinclude entry not found, skipping: $line" >&2
      continue
    fi
    mkdir -p "$(dirname "$dst")"
    if [[ "$mode" == symlink ]]; then
      ln -sf "$src" "$dst"
      echo "Symlinked $line" >&2
    else
      cp -R "$src" "$dst"
      echo "Copied $line" >&2
    fi
  done < "$REPO_ROOT/.worktreeinclude"
else
  # Fallback (no .worktreeinclude): historical behavior — copy gitignored .env*,
  # symlink untracked .claude/ files.
  for env_file in "$REPO_ROOT"/.env*; do
    [[ -f "$env_file" ]] || continue
    filename=$(basename "$env_file")
    if git -C "$REPO_ROOT" check-ignore -q "$env_file" 2>/dev/null; then
      cp "$env_file" "$WORKTREE_DIR/$filename"
      echo "Copied $filename" >&2
    fi
  done

  if [[ -d "$REPO_ROOT/.claude" ]]; then
    while IFS= read -r rel_path; do
      [[ -z "$rel_path" ]] && continue
      src="$REPO_ROOT/$rel_path"
      target="$WORKTREE_DIR/$rel_path"
      mkdir -p "$(dirname "$target")"
      ln -sf "$src" "$target"
      echo "Symlinked $rel_path" >&2
    done < <(
      comm -23 \
        <(find "$REPO_ROOT/.claude" -type f -not -path "$REPO_ROOT/.claude/worktrees/*" | sed "s|$REPO_ROOT/||" | sort) \
        <(git -C "$REPO_ROOT" ls-files .claude/ | sort)
    )
  fi
fi

# Concern 3 — Setup. A repo-shipped, trust-gated .worktree/post_create owns
# setup entirely when present (autodetect is skipped). When present-but-untrusted
# it is skipped with a warning and autodetect is still skipped (the repo opted
# out). A trusted hook that fails is fatal — the ERR trap removes the worktree.
POST_CREATE="$REPO_ROOT/.worktree/post_create"
if [[ -f "$POST_CREATE" ]]; then
  if trust_check "$POST_CREATE"; then
    echo "Running .worktree/post_create ($POST_CREATE)..." >&2
    # Explicit failure handling: the ERR trap doesn't fire for failing subshells
    # on bash 3.2 (macOS), so clean up here so a bad hook never strands a worktree.
    if ! (cd "$WORKTREE_DIR" && WORKTREE_DIR="$WORKTREE_DIR" REPO_ROOT="$REPO_ROOT" bash "$POST_CREATE" >&2); then
      if [[ "$ON_FAIL" == remove ]]; then
        echo ".worktree/post_create failed — removing worktree..." >&2
        git -C "$REPO_ROOT" worktree remove --force "$WORKTREE_DIR" 2>/dev/null || true
      else
        echo ".worktree/post_create failed — leaving worktree in place ($WORKTREE_DIR)." >&2
      fi
      exit 1
    fi
  else
    # Present but untrusted: DON'T silently skip. An unprovisioned worktree that
    # exits 0 looks successful — the herdr pane closes, Claude reports done — and
    # the missing setup (deps, mise trust, DBs) only surfaces later as breakage.
    # Fail loudly with a distinct code (3 = "created but not provisioned") so every
    # caller reports it. The worktree is fine and intentionally KEPT: disarm the
    # cleanup trap and print the exact commands to trust + provision in place.
    trap - ERR
    {
      echo ""
      echo "═══════════════════════════════════════════════════════════════"
      echo "  ⚠  WORKTREE CREATED BUT NOT PROVISIONED"
      echo "═══════════════════════════════════════════════════════════════"
      echo "  $POST_CREATE"
      echo "  is untrusted, so NO setup ran (deps, mise trust, DBs, etc.)."
      echo "  A hook re-locks itself whenever its contents change."
      echo ""
      echo "  Review it, then trust + provision in place:"
      echo "    \"\$CLAUDE_PLUGIN_ROOT/scripts/worktree-trust\" allow \"$POST_CREATE\""
      echo "    \"\$CLAUDE_PLUGIN_ROOT/scripts/worktree-create\" \"$REPO_ROOT\" \"$BRANCH\" \"\" \"$WORKTREE_DIR\""
      echo "═══════════════════════════════════════════════════════════════"
      echo ""
    } >&2
    echo "$WORKTREE_DIR"
    exit 3
  fi
else
  if [[ -f "$REPO_ROOT/mix.exs" ]]; then
    if [[ -d "$REPO_ROOT/deps" ]]; then
      echo "Cloning deps/..." >&2
      clone_dir "$REPO_ROOT/deps" "$WORKTREE_DIR/deps"
    fi
    echo "Running mix deps.get..." >&2
    (cd "$WORKTREE_DIR" && mix deps.get >&2)
  fi

  if [[ -f "$REPO_ROOT/package.json" ]]; then
    if [[ -d "$REPO_ROOT/node_modules" ]]; then
      echo "Cloning node_modules/..." >&2
      clone_dir "$REPO_ROOT/node_modules" "$WORKTREE_DIR/node_modules"
    fi
    if [[ -f "$REPO_ROOT/pnpm-lock.yaml" ]]; then
      (cd "$WORKTREE_DIR" && pnpm install >&2)
    elif [[ -f "$REPO_ROOT/yarn.lock" ]]; then
      (cd "$WORKTREE_DIR" && yarn install >&2)
    else
      (cd "$WORKTREE_DIR" && npm install >&2)
    fi
  fi

  if [[ -f "$REPO_ROOT/pyproject.toml" ]]; then
    if command -v uv &>/dev/null; then
      (cd "$WORKTREE_DIR" && uv sync >&2)
    else
      echo "Warning: pyproject.toml found but uv not installed — skipping Python deps" >&2
    fi
  elif [[ -f "$REPO_ROOT/requirements.txt" ]]; then
    (cd "$WORKTREE_DIR" && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt >&2)
  fi

  if [[ -f "$REPO_ROOT/Cargo.toml" ]]; then
    (cd "$WORKTREE_DIR" && cargo fetch >&2)
  fi

  if [[ -f "$REPO_ROOT/go.mod" ]]; then
    (cd "$WORKTREE_DIR" && go mod download >&2)
  fi

  # Per-directory init: tools that key off path treat the worktree as new/untrusted.
  # Non-fatal — a missing optional tool must not trigger the ERR trap.
  # Match any of mise's config filenames (dotted and dotless, incl. .config/).
  if command -v mise &>/dev/null && [[ \
    -f "$WORKTREE_DIR/mise.toml" || -f "$WORKTREE_DIR/.mise.toml" || \
    -f "$WORKTREE_DIR/mise/config.toml" || -f "$WORKTREE_DIR/.config/mise.toml" || \
    -f "$WORKTREE_DIR/.config/mise/config.toml" || -f "$WORKTREE_DIR/.tool-versions" ]]; then
    (cd "$WORKTREE_DIR" && mise trust && mise install) >&2 || echo "Warning: mise setup failed" >&2
  fi

  if [[ -f "$WORKTREE_DIR/.envrc" ]] && command -v direnv &>/dev/null; then
    (cd "$WORKTREE_DIR" && direnv allow) >&2 || echo "Warning: direnv allow failed" >&2
  fi

  if [[ -f "$WORKTREE_DIR/.gitmodules" ]]; then
    git -C "$WORKTREE_DIR" submodule update --init --recursive >&2 || echo "Warning: submodule init failed" >&2
  fi

  if [[ -f "$WORKTREE_DIR/.gitattributes" ]] && grep -q 'filter=lfs' "$WORKTREE_DIR/.gitattributes" && command -v git-lfs &>/dev/null; then
    git -C "$WORKTREE_DIR" lfs pull >&2 || echo "Warning: git lfs pull failed" >&2
  fi

  if [[ -f "$WORKTREE_DIR/.pre-commit-config.yaml" ]] && command -v pre-commit &>/dev/null; then
    (cd "$WORKTREE_DIR" && pre-commit install) >&2 || echo "Warning: pre-commit install failed" >&2
  fi

  if compgen -G "$WORKTREE_DIR/lefthook.y*ml" >/dev/null 2>&1 || compgen -G "$WORKTREE_DIR/.lefthook.y*ml" >/dev/null 2>&1 || [[ -f "$WORKTREE_DIR/lefthook.toml" ]]; then
    if command -v lefthook &>/dev/null; then
      (cd "$WORKTREE_DIR" && lefthook install) >&2 || echo "Warning: lefthook install failed" >&2
    fi
  fi
fi

echo "Worktree ready: $WORKTREE_DIR" >&2
echo "$WORKTREE_DIR"
