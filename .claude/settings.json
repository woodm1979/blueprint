{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-plugin-version-bump.sh",
            "if": "Bash(git push*)",
            "statusMessage": "Checking plugin version bump..."
          }
        ]
      }
    ]
  }
}
